    {
      "type": "range",
      "id": "bottom_text_top",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Bottom text margin top",
      "default": 16
    },
    {
      "type": "range",
      "id": "hero_min_height_desktop",
      "min": 420,
      "max": 1100,
      "step": 10,
      "unit": "px",
      "label": "Banner image height desktop",
      "default": 780
    },
    {
      "type": "range",
      "id": "hero_min_height_mobile",
      "min": 240,
      "max": 700,
      "step": 10,
      "unit": "px",
      "label": "Banner image height mobile",
      "default": 420
    },
    {
      "type": "select",
      "id": "color_scheme",
      "default": "background-1",
      "label": "Color scheme",
      "options": [
        {
          "value": "background-1",
          "label": "Background-1"
        },
        {
          "value": "background-2",
          "label": "Background-2"
        },
        {
          "value": "background-3",
          "label": "Background-3"
        }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Section padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Section padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Gift Guide Banner"
    }
  ]
}
{% endschema %}
