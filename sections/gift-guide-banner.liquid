{{ 'gift-guide-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="gift-guide-banner color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding"
  data-gift-guide-banner="{{ section.id }}"
  style="
    --gift-guide-banner-top-row-gap: {{ section.settings.top_row_gap | default: 24 }}px;
    --gift-guide-banner-top-row-padding-x: {{ section.settings.top_row_padding_x | default: 50 }}px;
    --gift-guide-banner-top-row-padding-y: {{ section.settings.top_row_padding_y | default: 10 }}px;
    --gift-guide-banner-top-logo-width: {{ section.settings.top_logo_width | default: 152 }}px;
    --gift-guide-banner-top-text-top: {{ section.settings.top_text_top | default: 0 }}px;
    --gift-guide-banner-top-text-bottom: {{ section.settings.top_text_bottom | default: 0 }}px;
    --gift-guide-banner-top-button-top: {{ section.settings.top_button_top | default: 0 }}px;
    --gift-guide-banner-top-button-bottom: {{ section.settings.top_button_bottom | default: 0 }}px;
    --gift-guide-banner-hero-content-top: {{ section.settings.hero_content_top | default: 70 }}px;
    --gift-guide-banner-hero-content-left: {{ section.settings.hero_content_left | default: 40 }}px;
    --gift-guide-banner-hero-content-max-width: {{ section.settings.hero_content_max_width | default: 460 }}px;
    --gift-guide-banner-hero-button-top: {{ section.settings.hero_button_top | default: 24 }}px;
    --gift-guide-banner-hero-button-bottom: {{ section.settings.hero_button_bottom | default: 0 }}px;
    --gift-guide-banner-bottom-text-top: {{ section.settings.bottom_text_top | default: 16 }}px;
    --gift-guide-banner-hero-min-height-desktop: {{ section.settings.hero_min_height_desktop | default: 780 }}px;
    --gift-guide-banner-hero-min-height-mobile: {{ section.settings.hero_min_height_mobile | default: 420 }}px;
    --gift-guide-banner-logo-font-size: {{ section.settings.logo_font_size | default: 16 }}px;
    --gift-guide-banner-top-text-font-size: {{ section.settings.top_text_font_size | default: 16 }}px;
    --gift-guide-banner-top-button-font-size: {{ section.settings.top_button_font_size | default: 16 }}px;
    --gift-guide-banner-overlay-title-font-size: {{ section.settings.overlay_title_font_size | default: 76 }}px;
    --gift-guide-banner-overlay-description-font-size: {{ section.settings.overlay_description_font_size | default: 16 }}px;
    --gift-guide-banner-overlay-button-font-size: {{ section.settings.overlay_button_font_size | default: 16 }}px;
    --gift-guide-banner-bottom-text-font-size: {{ section.settings.bottom_text_font_size | default: 12 }}px;
  "
>
  {%- assign bottom_text_mobile = section.settings.bottom_text_mobile | default: section.settings.bottom_text -%}
  {%- assign overlay_description_mobile = section.settings.overlay_description_mobile | default: section.settings.overlay_description -%}

  <div class="gift-guide-banner__shell">
    <div class="gift-guide-banner__top-row">
      <button
        type="button"
        class="gift-guide-banner__menu-toggle"
        aria-label="Menu"
        data-gift-guide-banner-menu-toggle
      >
        <svg width="18" height="10" viewBox="0 0 18 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
          <path d="M0 1H18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          <path d="M0 5H18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          <path d="M0 9H18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </button>

      <div class="gift-guide-banner__logo-wrap">
        {%- if section.settings.logo_image != blank -%}
          <img
            class="gift-guide-banner__logo-image"
            src="{{ section.settings.logo_image | image_url: width: 320 }}"
            alt="{{ section.settings.logo_alt | escape }}"
            width="{{ section.settings.logo_image.width }}"
            height="{{ section.settings.logo_image.height }}"
            loading="lazy"
          >
        {%- else -%}
          <span class="gift-guide-banner__logo-text">{{ section.settings.logo_alt | escape }}</span>
        {%- endif -%}
      </div>

      <div class="gift-guide-banner__top-text-wrap">
        <p class="gift-guide-banner__top-text">{{ section.settings.top_text | escape }}</p>
      </div>

      {%- if section.settings.top_button_link != blank -%}
        <a class="gift-guide-banner__top-button" href="{{ section.settings.top_button_link }}">
      {%- else -%}
        <div class="gift-guide-banner__top-button" role="presentation">
      {%- endif -%}
          <span class="gift-guide-banner__button-label">{{ section.settings.top_button_text | escape }}</span>
          <svg class="gift-guide-banner__arrow" viewBox="0 0 20 16" aria-hidden="true" focusable="false">
            <path d="M12 0L10.59 1.41L16.17 7H0V9H16.17L10.59 14.59L12 16L20 8L12 0Z" fill="currentColor"></path>
          </svg>
      {%- if section.settings.top_button_link != blank -%}
        </a>
      {%- else -%}
        </div>
      {%- endif -%}
    </div>

    <template data-gift-guide-banner-drawer-template>
      <div class="gift-guide-banner__drawer-block">
        {%- if section.settings.top_text != blank -%}
          <p class="gift-guide-banner__drawer-text">{{ section.settings.top_text | escape }}</p>
        {%- endif -%}

        {%- if section.settings.top_button_text != blank -%}
          {%- if section.settings.top_button_link != blank -%}
            <a class="gift-guide-banner__drawer-button" href="{{ section.settings.top_button_link }}">
          {%- else -%}
            <div class="gift-guide-banner__drawer-button" role="presentation">
          {%- endif -%}
              <span class="gift-guide-banner__button-label">{{ section.settings.top_button_text | escape }}</span>
              <svg class="gift-guide-banner__arrow" viewBox="0 0 20 16" aria-hidden="true" focusable="false">
                <path d="M12 0L10.59 1.41L16.17 7H0V9H16.17L10.59 14.59L12 16L20 8L12 0Z" fill="currentColor"></path>
              </svg>
          {%- if section.settings.top_button_link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>
    </template>

    <div class="gift-guide-banner__hero">
      {%- if section.settings.hero_image != blank -%}
        <img
          class="gift-guide-banner__hero-image"
          src="{{ section.settings.hero_image | image_url: width: 2200 }}"
          alt="{{ section.settings.hero_image_alt | escape }}"
          width="{{ section.settings.hero_image.width }}"
          height="{{ section.settings.hero_image.height }}"
          loading="lazy"
        >
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'gift-guide-banner__hero-placeholder' }}
      {%- endif -%}

      <div class="gift-guide-banner__overlay">
        <div class="gift-guide-banner__overlay-content">
          {%- if section.settings.overlay_title != blank -%}
            <h2 class="gift-guide-banner__overlay-title">{{ section.settings.overlay_title | escape }}</h2>
          {%- endif -%}

          {%- if section.settings.overlay_description != blank -%}
            <div class="gift-guide-banner__overlay-description">
              <div class="gift-guide-banner__overlay-description-inner gift-guide-banner__overlay-description-inner--desktop">{{ section.settings.overlay_description }}</div>
              {%- if overlay_description_mobile != blank -%}
                <div class="gift-guide-banner__overlay-description-inner gift-guide-banner__overlay-description-inner--mobile">{{ overlay_description_mobile }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if section.settings.overlay_button_link != blank -%}
            <a class="gift-guide-banner__overlay-button" href="{{ section.settings.overlay_button_link }}">
          {%- else -%}
            <div class="gift-guide-banner__overlay-button" role="presentation">
          {%- endif -%}
              <span class="gift-guide-banner__button-label">{{ section.settings.overlay_button_text | escape }}</span>
              <svg class="gift-guide-banner__wide-arrow" viewBox="0 0 24 12" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                <path d="M0 6H18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                <path d="M18 6L13.5 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M18 6L13.5 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <svg class="gift-guide-banner__arrow" viewBox="0 0 20 16" aria-hidden="true" focusable="false">
                <path d="M12 0L10.59 1.41L16.17 7H0V9H16.17L10.59 14.59L12 16L20 8L12 0Z" fill="currentColor"></path>
              </svg>
          {%- if section.settings.overlay_button_link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>

    {%- if section.settings.bottom_text != blank or bottom_text_mobile != blank -%}
      <div class="gift-guide-banner__bottom-text">
        {%- if section.settings.bottom_text != blank -%}
          <div class="gift-guide-banner__bottom-text-inner gift-guide-banner__bottom-text-inner--desktop">{{ section.settings.bottom_text }}</div>
        {%- endif -%}
        {%- if bottom_text_mobile != blank -%}
          <div class="gift-guide-banner__bottom-text-inner gift-guide-banner__bottom-text-inner--mobile">{{ bottom_text_mobile }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

<script src="{{ 'gift-guide-banner.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Gift Guide Banner",
  "tag": "section",
  "class": "section section-gift-guide-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Top logo image"
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Top logo text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "top_text",
      "label": "Top center text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "top_button_text",
      "label": "Top button text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "top_button_link",
      "label": "Top button link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Banner image"
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Banner image alt text",
      "default": "Gift guide banner image"
    },
    {
      "type": "text",
      "id": "overlay_title",
      "label": "Banner heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "overlay_description",
      "label": "Banner description",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "textarea",
      "id": "overlay_description_mobile",
      "label": "Banner description (mobile)",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination."
    },
    {
      "type": "text",
      "id": "overlay_button_text",
      "label": "Banner button text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "overlay_button_link",
      "label": "Banner button link"
    },
    {
      "type": "inline_richtext",
      "id": "bottom_text",
      "label": "Bottom text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
      "type": "inline_richtext",
      "id": "bottom_text_mobile",
      "label": "Bottom text (mobile)",
      "default": "SUSTAINABLE, ETHICALLY MADE ACTIVEWEAR"
    },
    {
      "type": "range",
      "id": "logo_font_size",
      "min": 10,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Logo text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "top_text_font_size",
      "min": 10,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Top text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "top_button_font_size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Choose Gift button text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "overlay_title_font_size",
      "min": 24,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Hero heading size",
      "default": 76
    },
    {
      "type": "range",
      "id": "overlay_description_font_size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Hero description size",
      "default": 16
    },
    {
      "type": "range",
      "id": "overlay_button_font_size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Shop Now button text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "bottom_text_font_size",
      "min": 8,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Bottom text size",
      "default": 12
    },
    {
      "type": "range",
      "id": "top_row_gap",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Top row gap",
      "default": 24
    },
    {
      "type": "range",
      "id": "top_row_padding_x",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Top row side padding",
      "default": 50
    },
    {
      "type": "range",
      "id": "top_row_padding_y",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Top row vertical padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "top_logo_width",
      "min": 80,
      "max": 260,
      "step": 2,
      "unit": "px",
      "label": "Top logo width",
      "default": 152
    },
    {
      "type": "range",
      "id": "top_text_top",
      "min": -40,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Top text margin top",
      "default": 0
    },
    {
      "type": "range",
      "id": "top_text_bottom",
      "min": -40,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Top text margin bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "top_button_top",
      "min": -40,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Top button margin top",
      "default": 0
    },
    {
      "type": "range",
      "id": "top_button_bottom",
      "min": -40,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Top button margin bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "hero_content_top",
      "min": 0,
      "max": 420,
      "step": 5,
      "unit": "px",
      "label": "Banner content top offset",
      "default": 70
    },
    {
      "type": "range",
      "id": "hero_content_left",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Banner content left offset",
      "default": 40
    },
    {
      "type": "range",
      "id": "hero_content_max_width",
      "min": 260,
      "max": 700,
      "step": 10,
      "unit": "px",
      "label": "Banner content width",
      "default": 460
