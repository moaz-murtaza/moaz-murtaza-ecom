{{ 'product-grid-modal.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .product-grid-modal[data-section-id="{{ section.id }}"] {
    --product-grid-modal-open-icon-top: {{ section.settings.open_icon_top | default: 50 }};
    --product-grid-modal-open-icon-right: {{ section.settings.open_icon_right | default: 3 }};
    --product-grid-modal-open-icon-left: {{ section.settings.open_icon_left | default: 97 }};
  }
{%- endstyle -%}

<section class="product-grid-modal color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.title -%}
      <h2 class="product-grid-modal__title h2">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="product-grid-modal__grid" data-grid-id="{{ section.id }}">
      {%- for i in (1..6) -%}
        {%- assign product_setting = 'product_' | append: i -%}
        {%- assign product = section.settings[product_setting] -%}
        
        {%- if product != blank -%}
          <div class="product-grid-modal__item" data-product-id="{{ product.id }}" data-product-handle="{{ product.handle }}">
            <div class="product-grid-modal__card">
              {%- if product.featured_image -%}
                <div class="product-grid-modal__image-wrapper">
                  {%- liquid
                    assign top_key = 'open_icon_' | append: i | append: '_top'
                    assign left_key = 'open_icon_' | append: i | append: '_left'
                    assign icon_top = section.settings[top_key] | default: section.settings.open_icon_top | default: 50
                    assign icon_left = section.settings[left_key] | default: section.settings.open_icon_left
                    if icon_left == blank
                      assign icon_right = section.settings.open_icon_right | default: 3
                      assign icon_left = 100 | minus: icon_right
                    endif
                  -%}
                  {%- capture icon_vars -%}--product-grid-modal-open-icon-top: {{ icon_top }}; --product-grid-modal-open-icon-left: {{ icon_left }};{%- endcapture -%}
                  <img 
                    src="{{ product.featured_image | image_url: width: 300 }}" 
                    alt="{{ product.title }}"
                    class="product-grid-modal__image"
                    width="300"
                    height="300"
                  >
                  <button class="product-grid-modal__open-btn" type="button" aria-label="Open product details" style="{{ icon_vars | strip }}">
                    <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <circle cx="11" cy="11" r="10" fill="white" stroke="#BDBDBD"/>
                      <path d="M11 7V15M7 11H15" stroke="#1D1D1D" stroke-linecap="round"/>
                    </svg>
                  </button>
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<!-- Product Detail Modal -->
<div class="product-detail-modal" id="productModal-{{ section.id }}" data-modal-id="{{ section.id }}">
  <div class="product-detail-modal__overlay" data-modal-close>
    <div class="product-detail-modal__content">
      <button class="product-detail-modal__close" type="button" aria-label="Close modal" data-modal-close>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>

      <div class="product-detail-modal__container">
        <div class="product-detail-modal__top">
          <!-- Image section -->
          <div class="product-detail-modal__image-section">
            <img class="product-detail-modal__image" data-modal-image src="" alt="">
          </div>

          <!-- Details section -->
          <div class="product-detail-modal__details-section">
            <h2 class="product-detail-modal__title" data-modal-title></h2>
            
            <p class="product-detail-modal__price" data-modal-price></p>
            
            <p class="product-detail-modal__description" data-modal-description></p>
          </div>
        </div>

        <!-- Variants section -->
        <div class="product-detail-modal__variants" data-modal-variants>
          <!-- Dynamically populated -->
        </div>

        <!-- Add to Cart button -->
        <button class="button button-primary product-detail-modal__add-to-cart" type="button" data-modal-add-to-cart>
          ADD TO CART
          <svg class="button-arrow" width="20" height="16" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 0L10.59 1.41L16.17 7H0V9H16.17L10.59 14.59L12 16L20 8L12 0Z" fill="currentColor"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<script src="{{ 'product-grid-modal.js' | asset_url }}" defer="defer"></script>

